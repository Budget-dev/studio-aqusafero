{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the registered user.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "phone": {
          "type": "string",
          "description": "The user's contact number."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The user's permission level."
        }
      },
      "required": ["email"]
    }
  },
  "auth": {
    "providers": ["email/password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/User",
      "description": "User profile documents."
    }
  }
}
