
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the registered user.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"]
        },
        "phone": {
          "type": "string",
          "description": "User's mobile number"
        },
        "age": {
          "type": "number",
          "description": "User's age"
        }
      },
      "required": ["email"]
    },
    "Product": {
      "title": "Product",
      "description": "Advanced water treatment product details.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "category": { 
          "type": "string", 
          "enum": [
            "Domestic Products", 
            "Commercial Products", 
            "Institutional Products", 
            "Industrial Products", 
            "Components & Spare Parts", 
            "Filters & Chemicals"
          ] 
        },
        "subcategory": { "type": "string" },
        "type": { "type": "string", "enum": ["Product", "Spare Part"] },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "offerPrice": { "type": "number" },
        "sku": { "type": "string" },
        "stock": { "type": "number" },
        "images": { "type": "object" },
        "description": { "type": "string" },
        "specifications": { "type": "array" },
        "featured": { "type": "boolean" }
      }
    },
    "Order": {
      "title": "Customer Order",
      "description": "Sales records from the storefront.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "customerName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["PhonePe", "Razorpay"] },
        "paymentReference": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Shipped", "Delivered"] },
        "createdAt": { "type": "string" }
      }
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "Image or video for the public gallery.",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video"] },
        "description": { "type": "string" },
        "category": { "type": "string" }
      }
    },
    "Brand": {
      "title": "Brand Partner",
      "description": "Technical partner and component manufacturers.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "description": { "type": "string" },
        "website": { "type": "string" },
        "featured": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["email/password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/User",
      "description": "User profiles."
    },
    "/products/{productId}": {
      "schema": "#/entities/Product",
      "description": "Main product catalog."
    },
    "/orders/{orderId}": {
      "schema": "#/entities/Order",
      "description": "Customer purchase records."
    },
    "/gallery/{itemId}": {
      "schema": "#/entities/GalleryItem",
      "description": "Gallery media."
    },
    "/brands/{brandId}": {
      "schema": "#/entities/Brand",
      "description": "Partner brands."
    }
  }
}
