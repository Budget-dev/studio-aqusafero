
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the registered user.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"]
        },
        "phone": {
          "type": "string",
          "description": "User's mobile number"
        },
        "age": {
          "type": "number",
          "description": "User's age"
        }
      },
      "required": ["email"]
    },
    "Product": {
      "title": "Product",
      "description": "Advanced water treatment product details.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "category": { 
          "type": "string", 
          "enum": [
            "Domestic Products", 
            "Commercial Products", 
            "Institutional Products", 
            "Industrial Products", 
            "Components & Spare Parts", 
            "Filters & Chemicals"
          ] 
        },
        "subcategory": { "type": "string" },
        "type": { "type": "string", "enum": ["Product", "Spare Part"] },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "offerPrice": { "type": "number" },
        "sku": { "type": "string" },
        "stock": { "type": "number" },
        "images": { "type": "array", "items": { "type": "object", "properties": { "url": { "type": "string" }, "caption": { "type": "string" } } } },
        "videos": { "type": "array", "items": { "type": "object", "properties": { "url": { "type": "string" }, "caption": { "type": "string" } } } },
        "description": { "type": "string" },
        "specifications": { "type": "array", "items": { "type": "object", "properties": { "key": { "type": "string" }, "value": { "type": "string" } } } },
        "featured": { "type": "boolean" },
        "seo": { "type": "object", "properties": { "title": { "type": "string" }, "description": { "type": "string" } } }
      }
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "Image or video for the public gallery.",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video"] },
        "description": { "type": "string" },
        "category": { "type": "string" }
      }
    },
    "Brand": {
      "title": "Brand Partner",
      "description": "Technical partner and component manufacturers.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "description": { "type": "string" },
        "website": { "type": "string" },
        "featured": { "type": "boolean" }
      }
    },
    "Review": {
      "title": "Customer Review",
      "description": "Feedback and ratings for products/services.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved"] }
      }
    },
    "Coupon": {
      "title": "Commercial Incentive",
      "description": "Discount codes and special offers.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discount": { "type": "number" },
        "expiry": { "type": "string" },
        "active": { "type": "boolean" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Professional billing records.",
      "type": "object",
      "properties": {
        "invoiceNo": { "type": "string" },
        "customerName": { "type": "string" },
        "date": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Paid", "Pending"] }
      }
    }
  },
  "auth": {
    "providers": ["email/password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/User",
      "description": "User profiles."
    },
    "/products/{productId}": {
      "schema": "#/entities/Product",
      "description": "Main product catalog."
    },
    "/gallery/{itemId}": {
      "schema": "#/entities/GalleryItem",
      "description": "Gallery media."
    },
    "/brands/{brandId}": {
      "schema": "#/entities/Brand",
      "description": "Partner brands."
    },
    "/reviews/{reviewId}": {
      "schema": "#/entities/Review",
      "description": "Customer feedback."
    },
    "/coupons/{couponId}": {
      "schema": "#/entities/Coupon",
      "description": "Discount codes."
    },
    "/invoices/{invoiceId}": {
      "schema": "#/entities/Invoice",
      "description": "Sales records."
    }
  }
}
