
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // CRITICAL: Hardcoded Admin Identity
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'aquasaferoworks@gmail.com';
    }

    // Orders: Anyone can create, only Admin can list all, users can read their own
    match /orders/{orderId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    // Catalog & Media: Publicly readable, but only hardcoded admin can modify
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /gallery/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // System config
    match /system/config {
      allow read: if true;
      allow create: if request.resource.data.adminInitialized == true;
      allow update, delete: if isAdmin();
    }
  }
}
